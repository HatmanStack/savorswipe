{
  "name": "savorswipe",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "start": "cp .env frontend/.env 2>/dev/null || true; cd frontend && expo start",
    "reset-project": "node ./frontend/scripts/reset-project.js",
    "android": "cp .env frontend/.env 2>/dev/null || true; cd frontend && expo start --android",
    "ios": "cp .env frontend/.env 2>/dev/null || true; cd frontend && expo start --ios",
    "web": "cp .env frontend/.env 2>/dev/null || true; cd frontend && expo start --web",
    "test": "jest --forceExit",
    "test:backend": "PYTHONPATH=backend pytest tests/backend -v --tb=short",
    "lint": "cd frontend && expo lint && npx tsc --noEmit",
    "lint:backend": "cd backend && uvx ruff check .",
    "lock:backend": "cd backend && uv lock && uv export --frozen --no-hashes --no-dev --no-emit-project > requirements.txt",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run lint:backend && jest --passWithNoTests --no-watch --ci --runInBand --forceExit && npm run test:backend",
    "deploy": "node ./frontend/scripts/deploy.js",
    "sitemap": "node ./frontend/scripts/generate-sitemap.js",
    "sitemap:api": "node ./frontend/scripts/generate-sitemap.js --api",
    "docs:lint": "markdownlint '**/*.md' --ignore-path .markdownlintignore",
    "docs:links": "lychee --config lychee.toml '**/*.md'",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/frontend",
      "<rootDir>/tests"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(?:jest-)?react-native|@react-native(?:-community)?|expo(?:nent)?|@expo(?:nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/backend/",
      "/tests/e2e/",
      "/__test_helpers__/",
      "/dist/"
    ],
    "setupFiles": [
      "<rootDir>/jest.globals.js",
      "<rootDir>/frontend/jest.mocks.js"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "<rootDir>/frontend/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/frontend/$1"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-navigation/native": "^7.3.13",
    "dotenv": "^17.4.2",
    "expo": "^57.0.7",
    "expo-constants": "~57.0.6",
    "expo-crypto": "^57.0.1",
    "expo-document-picker": "^57.0.1",
    "expo-file-system": "^57.0.1",
    "expo-font": "~57.0.1",
    "expo-image-manipulator": "~57.0.5",
    "expo-image-picker": "~57.0.5",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "pdf-lib": "^1.17.1",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-native": "^0.86.0",
    "react-native-gesture-handler": "~3.1.0",
    "react-native-reanimated": "~4.5.2",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.26.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.11.1",
    "react-native-worklets-core": "^1.6.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.7.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-native": "^5.4.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.17",
    "@types/react-test-renderer": "^18.0.7",
    "eslint": "^9.7.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "markdownlint-cli": "^0.41.0",
    "react-test-renderer": "19.2.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1"
  },
  "private": true
}
